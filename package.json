{
  "name": "envm",
  "version": "0.1.0",
  "description": "CLI tool for managing .env files — compare, merge, snapshot, validate",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "envm": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["env", "dotenv", "cli", "diff", "merge", "environment"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0"
  }
}
